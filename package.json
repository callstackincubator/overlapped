{
  "name": "ovelapped",
  "version": "0.1.0",
  "description": "Find unit tests whose coverage is fully subsumed by integration tests",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ovelapped": "bin/ovelapped.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "coverage",
    "testing",
    "vitest",
    "jest",
    "deduplication",
    "overlap"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.8"
  }
}
